# Application
ENVIRONMENT=development
LOG_LEVEL=DEBUG
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/psd_dev
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth0/JWT Authentication
AUTH0_DOMAIN=your-auth0-domain.auth0.com
AUTH0_AUDIENCE=https://api.example.com
AUTH0_ALGORITHMS=RS256
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Yoti Age Verification
YOTI_CLIENT_SDK_ID=your-yoti-client-sdk-id
YOTI_PEM_FILE=/path/to/yoti.pem

# BlueCheck Age Verification
BLUECHECK_API_KEY=your-bluecheck-api-key
BLUECHECK_API_URL=https://api.bluecheck.com.au

# Ondato Identity Verification
ONDATO_USERNAME=your-ondato-username
ONDATO_PASSWORD=your-ondato-password
ONDATO_ORGANIZATION_ID=your-ondato-org-id
ONDATO_API_URL=https://api.ondato.com

# CCBill Payment Processing
CCBILL_ACCOUNT_NUMBER=your-ccbill-account-number
CCBILL_SUB_ACCOUNT_NUMBER=your-ccbill-sub-account
CCBILL_SALT=your-ccbill-salt
CCBILL_FLEXID=your-ccbill-flexid
CCBILL_SALT_KEY=your-ccbill-salt-key
CCBILL_DATAFORM_SALT=your-ccbill-dataform-salt
CCBILL_API_URL=https://api.ccbill.com

# Paxum Payment Processing
PAXUM_API_KEY=your-paxum-api-key
PAXUM_API_URL=https://api.paxum.com

# Pipedrive CRM
PIPEDRIVE_API_TOKEN=your-pipedrive-api-token
PIPEDRIVE_API_URL=https://api.pipedrive.com

# HubSpot CRM
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_API_URL=https://api.hubapi.com

# Mautic Marketing Automation
MAUTIC_URL=https://your-mautic-instance.com
MAUTIC_USERNAME=your-mautic-username
MAUTIC_PASSWORD=your-mautic-password

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name
AWS_SES_FROM_EMAIL=noreply@example.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
