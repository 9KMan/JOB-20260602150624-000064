################################################################################
# Terraform.tfvars.example - Example Terraform Variables
# Copy this file to terraform.tfvars and update values for your environment
################################################################################

################################################################################
# AWS Configuration
################################################################################

aws_region = "us-east-1"

# Leave empty if using instance roles or environment credentials
# aws_access_key = ""
# aws_secret_key = ""

################################################################################
# Environment and Product Configuration
################################################################################

environment  = "prod"
product_name = "premium-service-directory"
team_name    = "platform-team"

################################################################################
# Tags Configuration
################################################################################

tags = {
  Environment = "prod"
  Product     = "premium-service-directory"
  Team        = "platform-team"
  ManagedBy   = "terraform"
  Compliance  = "soc2"
  CostCenter  = "platform-services"
}

################################################################################
# VPC Configuration
################################################################################

vpc_cidr = "10.0.0.0/16"

availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]

private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]

################################################################################
# KMS Configuration
################################################################################

# IAM users/roles who can administer KMS keys (key administrators)
kms_key_administrators = [
  "arn:aws:iam::123456789012:role/platform-admin",
  "arn:aws:iam::123456789012:user/security-admin"
]

# IAM users/roles who can use KMS keys for encryption/decryption
kms_key_users = [
  "arn:aws:iam::123456789012:role/ecs-task-execution-role",
  "arn:aws:iam::123456789012:role/rds-encryption-role"
]

################################################################################
# RDS Configuration
################################################################################

db_name     = "premium_directory"
db_username = "dbadmin"
db_port     = 5432

db_instance_class        = "db.r6g.xlarge"
db_allocated_storage     = 100
db_max_allocated_storage = 500
db_multi_az              = true

backup_retention_period = 7
backup_window           = "03:00-04:00"
maintenance_window      = "mon:04:00-mon:05:00"

enable_pgbouncer     = true
pgbouncer_pool_size  = 20

################################################################################
# ECS Configuration
################################################################################

ecs_desired_count       = 2
ecs_min_capacity        = 2
ecs_max_capacity        = 10
ecs_autoscaling_enabled = true

################################################################################
# Redis/ElastiCache Configuration
################################################################################

redis_node_type        = "cache.r6g.large"
redis_num_cache_nodes  = 2
redis_engine_version   = "7.0"
redis_port             = 6379

################################################################################
# Domain and DNS Configuration
################################################################################

domain_name = "premiumservicedirectory.com"

################################################################################
# Cognito Configuration
################################################################################

cognito_domain_name = "premium-service-directory-auth"

cognito_callback_urls = [
  "https://premiumservicedirectory.com/api/auth/callback",
  "https://premiumservicedirectory.com/api/auth/callback?prompt=consent"
]

cognito_logout_urls = [
  "https://premiumservicedirectory.com/api/auth/logout"
]

################################################################################
# CloudWatch Configuration
################################################################################

cloudwatch_log_retention_days = 30
alarm_email                   = "platform-alerts@premiumservicedirectory.com"